{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JasonTeixeira/Nexural_Automation/schemas/maintainer-attestation.schema.json",
  "title": "Qualified critical-path maintainer attestation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "github_login", "owner", "qualified", "competencies", "reviewed_commit", "critical_path_approval", "attested_at"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "github_login": {"type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"},
    "owner": {"type": "boolean"},
    "qualified": {"const": true},
    "competencies": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {"enum": ["ninjatrader", "csharp", "execution", "risk", "security", "release-engineering"]},
      "allOf": [
        {"contains": {"const": "ninjatrader"}},
        {"contains": {"const": "execution"}},
        {"contains": {"const": "risk"}},
        {"contains": {"const": "release-engineering"}}
      ]
    },
    "reviewed_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "critical_path_approval": {"const": true},
    "attested_at": {"type": "string", "format": "date-time"}
  }
}
