volInfluence = input.float(0.4, "Volatility Influence", minval=0.1, maxval=0.8, step=0.05, group=group2)
useVolumeDelta = input.bool(true, "Use Volume Delta Confirmation", group=group2)
volumeInfluence = input.float(0.35, "Volume Influence", minval=0.1, maxval=0.7, step=0.05, group=group2)
useRRED = input.bool(true, "Use Relative Range Expansion Detection", group=group2)
rredLookback = input.int(15, "RRED Lookback", minval=5, maxval=30, group=group2)

// Elite Edition Enhancement Settings
var group5 = "🚀 Elite Edition Settings"
useMarketRegimeDetection = input.bool(true, "Use Market Regime Detection", group=group5)
useVolumeFootprint = input.bool(true, "Use Advanced Volume Footprint", group=group5)
useStatFiltering = input.bool(true, "Use Statistical Filtering", group=group5)
useDynamicTimeframes = input.bool(false, "Use Dynamic Timeframe Selection", group=group5)
useHilbertTransform = input.bool(true, "Use True Hilbert Transform", group=group5)
regimeUpdateFreq = input.int(10, "Regime Update Frequency (bars)", minval=5, maxval=50, group=group5)

// Visual Settings
var group3 = "🎨 Visual Settings"
showCycles = input.bool(true, "Show Cycle Phase Line", group=group3)
useGradientColors = input.bool(true, "Use Gradient Colors for Histogram", group=group3)
showHistogram = input.bool(true, "Show Histogram", group=group3)
showProjection = input.bool(false, "Show Signal Projection", group=group3)

// Glow Effect Settings
showGlowEffects = input.bool(true, "Enable Histogram Glow Effects", group=group3)
showHeatMapBands = input.bool(true, "Enable Heat Map Bands at Extremes", group=group3)
// Tier 1 - Momentum Building (35-55)
glow1Threshold = input.int(35, "Tier 1: Building Momentum - Start", minval=20, maxval=50, group=group3)
glow1ThresholdHigh = input.int(55, "Tier 1: Building Momentum - End", minval=40, maxval=70, group=group3)
glow1Opacity = input.int(50, "Tier 1: Opacity %", minval=10, maxval=80, group=group3)
