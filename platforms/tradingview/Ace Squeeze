// ------------------------------ User Settings -------------------------------
// Core Settings
var group1 = "🎯 Core Settings"
length = input.int(20, "Base Cycle Length", minval=8, maxval=50, group=group1)
sensitivity = input.float(0.65, "Sensitivity", minval=0.2, maxval=0.95, step=0.05, group=group1)
bandsSrc = input(hlc3, "Price Source", group=group1)
useOpacityModulation = input.bool(true, "Vary Opacity by Signal Strength", group=group1)

// Enhancement Settings
var group2 = "⚛️ Enhancement Settings"
