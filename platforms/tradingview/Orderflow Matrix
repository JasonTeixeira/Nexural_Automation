bool showImbalanceBars = input.bool(true, "Show Imbalance Bars", group=grp_display, tooltip="Show the stacked buy/sell bars")
string textSizeInput = input.string("Tiny", "Text Size", options=["Auto", "Tiny", "Small"], group=grp_display)
bool showRowLabels = input.bool(true, "Show Row Labels", group=grp_display)
float rowHeight = input.float(1.0, "Row Height", minval=0.5, maxval=2.0, step=0.1, group=grp_display)
float activityThreshold = input.float(25.0, "Activity Threshold %", minval=10.0, maxval=50.0, step=5.0, tooltip="Below this delta %, colors fade to gray", group=grp_display)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS - IMBALANCE BARS
// ─────────────────────────────────────────────────────────────────────────────

grp_imbalance = "═══ Imbalance Bars ═══"
float imbalanceBarHeight = input.float(3.0, "Bar Height", minval=1.0, maxval=6.0, step=0.5, group=grp_imbalance)
bool showImbalanceLabels = input.bool(true, "Show Volume Labels", group=grp_imbalance)
bool showImbalancePct = input.bool(true, "Show Percentage", group=grp_imbalance)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS - METRICS
// ─────────────────────────────────────────────────────────────────────────────

grp_metrics = "═══ Metrics to Show ═══"
bool showVolume = input.bool(true, "Volume", inline="m1", group=grp_metrics)
bool showBarVWAP = input.bool(true, "Bar VWAP", inline="m1", group=grp_metrics)
bool showDelta = input.bool(true, "Delta", inline="m2", group=grp_metrics)
bool showDeltaPct = input.bool(true, "Delta %", inline="m2", group=grp_metrics)
bool showMaxDelta = input.bool(false, "Max Δ", inline="m3", group=grp_metrics)
bool showMinDelta = input.bool(false, "Min Δ", inline="m3", group=grp_metrics)
bool showBarCVD = input.bool(true, "Bar Δ CVD", inline="m4", group=grp_metrics)
