import TradingView/ta/10

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS - TIMEFRAME
// ─────────────────────────────────────────────────────────────────────────────

grp_ltf = "═══ Lower Timeframe ═══"
string ltfMode = input.string("Auto", "Timeframe Mode", options=["Auto", "Aggressive", "Conservative", "Custom"], group=grp_ltf)
string customTF = input.timeframe("1", "Custom Timeframe", group=grp_ltf)

// ─────────────────────────────────────────────────────────────────────────────
