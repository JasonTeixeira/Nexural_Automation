{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.nexural.io/schemas/academy-learning-item-v1.json",
  "title": "Nexural Academy learning item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "track", "title", "updated_at", "objectives", "translations", "execution", "rubric"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9_.-]+$"},
    "track": {"type": "string", "pattern": "^[a-z][a-z0-9-]+$"},
    "title": {"type": "string", "minLength": 3},
    "updated_at": {"type": "string", "format": "date"},
    "estimated_minutes": {"type": "integer", "minimum": 5},
    "objectives": {
      "type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}
    },
    "prerequisites": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "tags": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "translations": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-z]{2}(-[A-Z]{2})?$": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "summary"],
          "properties": {
            "title": {"type": "string", "minLength": 3},
            "summary": {"type": "string", "minLength": 3}
          }
        }
      },
      "additionalProperties": false
    },
    "hints": {"type": "array", "items": {"type": "string", "minLength": 3}},
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runner", "starter", "visible_tests", "hidden_tests", "solution", "expected_trace",
        "fault_profiles"
      ],
      "properties": {
        "runner": {"const": "nexural.declarative-trace.v1"},
        "starter": {"const": "starter/program.yaml"},
        "visible_tests": {"const": "tests/visible.yaml"},
        "hidden_tests": {"const": "tests/hidden.yaml"},
        "solution": {"const": "solution/program.yaml"},
        "expected_trace": {"const": "expected-trace.json"},
        "fault_profiles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["disconnect", "duplicate", "latency", "partial_fill", "stale_data"]
          }
        }
      }
    },
    "rubric": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "metric", "operator", "expected", "weight"],
        "properties": {
          "id": {"type": "string"},
          "metric": {"type": "string"},
          "operator": {
            "enum": [
              "equals", "not_equals", "gte", "lte", "contains", "not_contains",
              "truthy", "falsy", "unique"
            ]
          },
          "expected": {},
          "weight": {"type": "integer", "minimum": 1, "maximum": 100},
          "visibility": {"enum": ["public", "hidden"]},
          "message": {"type": "string"}
        }
      }
    }
  }
}
