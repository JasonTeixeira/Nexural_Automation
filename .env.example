SETUPTOOLS_USE_DISTUTILS=stdlib

# Local API defaults. Keep auth off for single-user local research, enable it
# before exposing the server to any shared workstation or remote client.
NEXURAL_AUTH_ENABLED=false
NEXURAL_API_KEYS=

# Restrict agent-readable CSV/report paths. Leave empty only for solo local use.
# Windows uses semicolons. macOS/Linux use colons.
NEXURAL_ALLOWED_DATA_DIRS=

# Default local dashboard and API origins.
NEXURAL_CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173

